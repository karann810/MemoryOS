# Copy to .env and fill in your values

# OpenAI (required — for embeddings + LLM)
OPENAI_API_KEY=sk-...

# Qdrant — episodic + working memory
# Cloud mode: use your Qdrant cloud URL and API key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # leave blank for local
QDRANT_COLLECTION=memories

# Remove all other vector DB configuration; this package now uses only Qdrant.

# Embedding model settings
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIM=1536

# Consolidation log path
CONSOLIDATION_LOG=docs/consolidation_log.jsonl
