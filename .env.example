# Copy to .env and fill in your values

# OpenAI (required — for embeddings + LLM)
OPENAI_API_KEY=sk-...

# Qdrant — episodic memory (Week 1-4)
# Local: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # leave blank for local
QDRANT_COLLECTION=memories

# Weaviate — semantic memory (Week 6)
# Free sandbox: https://console.weaviate.cloud
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your-weaviate-key

# Pinecone — working memory (Week 7)
# Free tier: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=working-memory

# Embedding model settings
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIM=1536

# Consolidation log path
CONSOLIDATION_LOG=docs/consolidation_log.jsonl
